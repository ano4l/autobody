# Copy to .env.local and fill in real values.
# .env.local is gitignored.

SPRING_PROFILES_ACTIVE=local

# ── Database (local docker-compose defaults) ─────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/autobody
DATABASE_USERNAME=autobody
DATABASE_PASSWORD=autobody_local

# ── Redis (local docker-compose default) ─────────────────────
REDIS_URL=redis://localhost:6379

# ── Security ─────────────────────────────────────────────────
JWT_SECRET=local-dev-secret-change-me-to-a-256-bit-random-string-for-production-use-only
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── CORS ─────────────────────────────────────────────────────
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Meta / WhatsApp ──────────────────────────────────────────
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=autobody_verify_2026
META_APP_SECRET=
META_STATE_TTL_MINUTES=30

# ── Shopify ──────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_SYNC_ENABLED=false
SHOPIFY_SYNC_CRON=0 0/15 * * * ?

# ── Resend ───────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=noreply@yourdomain.com

# ── Supabase Storage ─────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=autobody-media
