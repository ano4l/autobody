# All values are optional — the demo runs entirely on local seeded data.
# Provided here purely for documentation; safe to leave blank for Vercel.

# Public API base used by the (legacy) /lib/api fetcher. The redesigned
# dashboard does NOT call this; it pulls from the seeded in-memory store.
NEXT_PUBLIC_API_URL=

# Optional public site URL for canonical metadata.
NEXT_PUBLIC_SITE_URL=

# Demo login credentials (any value works — fake auth bypasses validation).
NEXT_PUBLIC_DEMO_EMAIL=demo@ferreiras.local
NEXT_PUBLIC_DEMO_PASSWORD=demo
