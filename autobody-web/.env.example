# Copy to .env.local — every value is optional. Leave them all blank to run
# the self-contained demo (seeded data, fake auth). Set the real-mode trio to
# wire the dashboard up to the Spring Boot backend in `../autobody-api`.

# ── Auth mode ────────────────────────────────────────────────────────────────
# "demo" (default): /login accepts any credentials, dashboard pulls from
#   src/lib/dashboard-autobody-seed.ts.
# "real":           /login POSTs /api/auth/login on the backend; the dashboard
#                   fetches live data and 401s redirect back to /login.
NEXT_PUBLIC_AUTH_MODE=

# ── Backend base URL ─────────────────────────────────────────────────────────
# Used by src/lib/api.ts AND by the /backend/* rewrite proxy in next.config.mjs.
# Browser default is the relative path "/backend" (which the rewrite forwards
# to http://localhost:8080). Override with a full https:// URL in production.
NEXT_PUBLIC_API_BASE_URL=

# ── Canonical site URL ───────────────────────────────────────────────────────
# Used by metadataBase + Open Graph + Twitter card tags in src/app/layout.tsx.
# Falls back to https://ferreiras-autobody.vercel.app if unset.
NEXT_PUBLIC_SITE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Real-mode example (uncomment to use against a locally-running autobody-api):
#   NEXT_PUBLIC_AUTH_MODE=real
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
# Default backend admin (from V5__seed_admin_user.sql):
#   admin@autobody.local / Admin@1234
